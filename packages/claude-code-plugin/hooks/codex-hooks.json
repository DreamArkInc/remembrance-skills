{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/codex-query-on-prompt.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*remembrance.*__(query_skills|get_skill|get_resource)|remembrance[._](query_skills|get_skill|get_resource)|query_skills|get_skill|get_resource",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/codex-record-detail-open.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/codex-contribute-on-stop.mjs\""
          }
        ]
      }
    ]
  }
}
