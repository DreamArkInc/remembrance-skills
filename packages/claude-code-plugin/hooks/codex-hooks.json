{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/codex-query-on-prompt.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*remembrance.*__(query_skills|get_skill|get_resource|invoke_skill|submit_query_feedback|submit_feedback|submit_remembrance|propose_skill_idea|submit_suggestion|submit_resource|submit_resource_review)|remembrance[._](query_skills|get_skill|get_resource|invoke_skill|submit_query_feedback|submit_feedback|submit_remembrance|propose_skill_idea|submit_suggestion|submit_resource|submit_resource_review)|query_skills|get_skill|get_resource|invoke_skill|submit_query_feedback|submit_feedback|submit_remembrance|propose_skill_idea|submit_suggestion|submit_resource|submit_resource_review",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/codex-record-detail-open.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/codex-contribute-on-stop.mjs\""
          }
        ]
      }
    ]
  }
}
